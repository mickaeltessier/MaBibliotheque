<m:MetroWindow x:Class="MaBibliotheque.Views.SubView.AddPublisherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:m="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:local="clr-namespace:MaBibliotheque.Views.SubView"
             xmlns:iconPacksMaterial="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="280" d:DesignWidth="150" WindowStyle="ToolWindow" ResizeMode="NoResize" Background="WhiteSmoke" Height="280" Width="150">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFB0BEC5" CornerRadius="5" Margin="5">
            <TextBlock Text="Ajouter un éditeur" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <Border Grid.Row="1" Margin="5" Padding="10" Background="#FFF0F0F0" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Nom de l'éditeur:"/>
                <TextBox Text="{Binding PublisherName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         Margin="0,5,0,10"/>
                <TextBlock Text="Ligne éditoriale:"/>
                <TextBox Text="{Binding EditorLine, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         Margin="0,5,0,10"/>
                <Button Content="Ajouter" Command="{Binding AddPublisherCommand}" HorizontalAlignment="Center" Margin="0,5,0,10"/>
            </StackPanel>
        </Border>
    </Grid>
</m:MetroWindow>