<m:MetroWindow x:Class="MaBibliotheque.Views.AddBookView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MaBibliotheque.Views"
      xmlns:m="http://metro.mahapps.com/winfx/xaml/controls"
      xmlns:iconPacksMaterial="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      d:DesignHeight="400" d:DesignWidth="250"
      Height="400" Width="250" ResizeMode="NoResize" WindowStyle="ToolWindow" Background="WhiteSmoke">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="30"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#FFB0BEC5" CornerRadius="5" Margin="5">
            <TextBlock Text="Ajouter un livre" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="5" Padding="10" Background="#FFF0F0F0" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Titre:"/>
                <TextBox Name="TitleTextBox" Text="{Binding Title}" Margin="0,5,0,10"/>
                <TextBlock Text="Auteur:"/>
                
                <DockPanel Margin="0,5,0,10">
                    <ListBox DockPanel.Dock="Left" Name="AuthorListBox" SelectionMode="Single" Width="200" Height="17">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Authors}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button DockPanel.Dock="Right" Command="{Binding AddAuthorCommand}" Width="17" Height="17" ToolTip="Ajouter un auteur">
                        <iconPacksMaterial:PackIconMaterial Kind="Plus" Width="10" Height="10"/>
                    </Button>
                </DockPanel>
                
                <TextBlock Text="Type:"/>
                <TextBox Name="BookType" Text="{Binding BookType}" Margin="0,5,0,10"/>
                <TextBlock Text="Année de publication:"/>
                <TextBox Name="YearTextBox" Text="{Binding PublishYear}" Margin="0,5,0,10"/>
                <TextBlock Text="Prix du livre:"/>
                <TextBox Name="Price" Text="{Binding Price}" Margin="0,5,0,10"/>
                <TextBlock Text="ISBN:"/>
                <TextBox Name="Isbn" Text="{Binding Isbn}" Margin="0,5,0,10"/>
                <Button Content="Ajouter" Command="{Binding AddBookCommand}" HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>
    </Grid>
</m:MetroWindow>
