<Window x:Class="MaBibliotheque.Views.LibraryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MaBibliotheque.Views"
        mc:Ignorable="d"
        d:DesignHeight="450" d:DesignWidth="800"
        Title="LibraryView">
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Background" Value="#FFF0F0F0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Title" Value="Ma Bibliothèque"/>
        </Style>
    </Window.Style>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="10">
            <Button Content="Ajouter un livre" Command="{Binding OpenAddBookViewCommand}" Margin="5"/>
            <Button Content="Supprimer un livre" Command="{Binding DeleteBookCommand}" Margin="5"/>
            <Button Content="Modifier un livre" Command="{Binding EditBookCommand}" Margin="5"/>
        </StackPanel>
        <ListView Name="BooksListView" Grid.Row="1" Margin="10" ItemsSource="{Binding Books, UpdateSourceTrigger=PropertyChanged, BindsDirectlyToSource=True}" SelectedItem="{Binding SelectedBook}" IsSynchronizedWithCurrentItem="True">
            <ListView.Style>
                <Style TargetType="ListView">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Background" Value="#FFF0F0F0"/>
                    <Setter Property="BorderBrush" Value="#FFB0B0B0"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </ListView.Style>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Titre" DisplayMemberBinding="{Binding Title}" Width="200"/>
                    <GridViewColumn Header="Auteur" DisplayMemberBinding="{Binding Author}" Width="150"/>
                    <GridViewColumn Header="Année de publication" DisplayMemberBinding="{Binding PublishYear}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
